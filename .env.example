# AssessApp Environment Variables
# Copy this file to .env and fill in the values

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of full origins (including scheme) that may POST
# to this app. Required in production behind Cloudflare Tunnel, e.g.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://assessapp.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Database
POSTGRES_DB=assessapp
POSTGRES_USER=assessapp
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Microsoft 365 SSO (Azure AD / Entra ID)
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=your-tenant-id
